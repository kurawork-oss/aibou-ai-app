# .env.example — 環境変数の見本（コピーして .env を作る／GitHub Secrets に設定する）
# ※ .env は .gitignore 済み。ローカル開発用。GitHub Actions では Secrets に同名で登録する。
#
# 【設計】鍵はアプリの Settings → Secure Vault に入れるのが基本（暗号化保存）。
#  GitHub Actions は下の3つ（Bootstrap）さえあれば、Vaultから自動で残りを読み込む。

# ── Bootstrap（headless / GitHub Actions に最低限必要）──────────────
SUPABASE_URL=
SUPABASE_KEY=
MASTER_ENCRYPTION_KEY=

# ── 以下は「Vaultに入れてあれば不要」。直接指定したい場合のみ ──────────
# AI（共通キー）
GEMINI_API_KEY=
# 用途別キー（マルチアカウント。未設定なら共通キーにフォールバック）
GEMINI_API_KEY_NIGHTLY=
GEMINI_API_KEY_ASSET_IMAGE=
# 画像生成モデルの上書き（任意）
GEMINI_IMAGE_MODEL=

# 通知（任意）
DISCORD_WEBHOOK=

# YouTube 公式アップロード（任意・設定した場合のみ配信）
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# Shutterstock 公式FTPS（任意・設定した場合のみ配信）
SS_FTP_HOST=
SS_FTP_USER=
SS_FTP_PASS=

# レンダリング（任意）
RENDER_MINUTES=10
RENDER_AUDIO_SEC=60
RENDER_TIMEOUT_SEC=1800
