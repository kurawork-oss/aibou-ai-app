# THE FORGE OS — frontend environment (copy to .env.local)
#
# Base URL of the AIbou Brain API (FastAPI backend). No trailing slash.
# Local dev example: http://localhost:8080
# Production example: https://your-backend.run.app
NEXT_PUBLIC_API_URL=

# Optional. If the backend sets APP_TOKEN, put the same value here and the
# frontend will send "Authorization: Bearer <token>" on protected routes.
NEXT_PUBLIC_API_TOKEN=

# Optional soft lock for the entry (login) screen. If set, the splash asks for
# this access code before entering. NOTE: this is a client-side deterrent only
# (the value is visible in the bundle) — not real authentication. Leave empty
# for a single "ENTER" tap.
NEXT_PUBLIC_GATE_PIN=
