# .env.example — AIbou Brain API の環境変数（コピーして .env を作る）
# 本番（Cloud Run / HF Spaces）は実環境変数 / Secrets に同名で設定する。

# 必須: Gemini（chat / vision を使うなら）
GEMINI_API_KEY=

# 任意: Supabase（記憶 memory / 収益 income を使うなら）。service role キーを推奨。
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# 任意: APIを保護するBearerトークン。設定すると /health 以外で
#       Authorization: Bearer <APP_TOKEN> が必須になる。空ならオープン。
APP_TOKEN=

# 任意: CORS許可オリジン。"*" で全許可。カンマ区切りで複数指定可
#       例: https://your-frontend.vercel.app
FRONTEND_ORIGIN=*
